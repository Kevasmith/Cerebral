# Encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-hex-char-key-here

# App
PORT=3000
NODE_ENV=development
# In production set NODE_ENV=production and CORS_ORIGIN to your Expo/web frontend URL.
# If CORS_ORIGIN is unset in production the server will reject all cross-origin requests.
CORS_ORIGIN=http://localhost:8081

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=yourpassword
DB_NAME=cerebral

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300


# OpenAI
OPENAI_API_KEY=sk-...

# Flinks
FLINKS_CUSTOMER_ID=your-flinks-customer-id
FLINKS_INSTANCE=your-flinks-instance

# Stripe — get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
