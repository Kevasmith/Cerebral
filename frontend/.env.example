# Copy this to .env and fill in your values
# All EXPO_PUBLIC_* vars are embedded at build time and visible to the client

# Backend API (use ngrok URL for device testing, Railway/Render URL for prod)
EXPO_PUBLIC_API_BASE=http://localhost:3000/api/v1

# Firebase — get these from your Firebase project settings
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
