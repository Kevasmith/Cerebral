{
  "expo": {
    "name": "Cerebral",
    "slug": "cerebral",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cerebral.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Cerebral uses your location to surface local opportunities."
      }
    },
    "android": {
      "package": "com.cerebral.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "permissions": [
        "NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "favicon": "./assets/icon.png",
      "name": "Cerebral",
      "shortName": "Cerebral",
      "description": "Your financial awareness starts here.",
      "themeColor": "#1a1a2e",
      "backgroundColor": "#f8f9fa"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1a1a2e"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d64603b1-35d7-4f8e-9666-e289de3a869c"
      }
    },
    "owner": "kevaughn"
  }
}
